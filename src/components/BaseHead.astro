---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE } from '../consts';
import { getLangFromPath, localizePath, stripLangPrefix, type Lang } from '../i18n';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata | string;
	imageAlt?: string;
	imageWidth?: number;
	imageHeight?: number;
	type?: 'website' | 'article' | 'profile' | 'product';
	structuredData?: unknown | unknown[];
	appStoreId?: string;
	alternateLanguages?: Partial<Record<Lang, string>>;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const lang = getLangFromPath(Astro.url.pathname);
const strippedPath = stripLangPrefix(Astro.url.pathname);
const englishURL = new URL(localizePath(strippedPath, 'en'), Astro.site);
const chineseURL = new URL(localizePath(strippedPath, 'zh'), Astro.site);
const rssURL = new URL(lang === 'zh' ? 'zh/rss.xml' : 'rss.xml', Astro.site);

const {
	title,
	description,
	image,
	imageAlt,
	imageWidth,
	imageHeight,
	type = 'website',
	structuredData,
	appStoreId,
	alternateLanguages,
} = Astro.props;
const locale = lang === 'zh' ? 'zh_CN' : 'en_US';
const languageLabels: Record<Lang, string> = {
	en: 'en',
	zh: 'zh-CN',
};
const defaultAlternateLanguages: Record<Lang, string> = {
	en: englishURL.href,
	zh: chineseURL.href,
};
const alternateLanguageEntries = Object.entries(alternateLanguages ?? defaultAlternateLanguages)
	.filter((entry): entry is [Lang, string] => Boolean(entry[1]))
	.map(([entryLang, href]) => ({
		lang: entryLang,
		href: new URL(href, Astro.site).href,
	}));
const xDefaultURL = new URL(alternateLanguages?.en ?? defaultAlternateLanguages.en, Astro.site).href;
const alternateOgLocales = alternateLanguageEntries
	.filter((entry) => entry.lang !== lang)
	.map((entry) => entry.lang === 'zh' ? 'zh_CN' : 'en_US');
const siteIdentityData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		url: new URL('/', Astro.site).href,
		inLanguage: lang === 'zh' ? 'zh-CN' : 'en',
		sameAs: ['https://x.com/blocktom'],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		name: 'Tom',
		url: new URL('/', Astro.site).href,
		sameAs: ['https://x.com/blocktom'],
	},
];
const structuredDataItems = Array.isArray(structuredData)
	? [...siteIdentityData, ...structuredData]
	: structuredData
		? [...siteIdentityData, structuredData]
		: siteIdentityData;

// 确定使用的图片 URL
// 如果有传入的图片，使用它；否则使用 Logo 作为默认
const defaultImageUrl = '/og-image.jpg';
let ogImageUrl: string;

if (image) {
	// 如果传入的是 ImageMetadata，使用其 src 属性；如果是字符串，直接使用
	const imagePath = typeof image === 'string' ? image : image.src;
	
	// 确保生成绝对 URL
	// 如果路径已经是绝对 URL，直接使用；否则基于 Astro.site 构建
	try {
		const url = new URL(imagePath, Astro.site);
		ogImageUrl = url.href;
	} catch {
		// 如果构建失败，使用默认 Logo
		ogImageUrl = new URL(defaultImageUrl, Astro.site).href;
	}
} else {
	// 使用默认 Logo
	ogImageUrl = new URL(defaultImageUrl, Astro.site).href;
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<!-- 防闪烁脚本：在页面加载前设置深色模式 -->
<script is:inline>
	(function() {
		try {
			const savedTheme = localStorage.getItem('theme');
			if (savedTheme === 'dark') {
				document.documentElement.classList.add('dark');
			} else if (!savedTheme && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
				document.documentElement.classList.add('dark');
			}
		} catch (e) {
			// 忽略 localStorage 错误
		}
	})();
</script>
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={rssURL}
/>
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index,follow,max-image-preview:large" />
{appStoreId && <meta name="apple-itunes-app" content={`app-id=${appStoreId}`} />}

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
{alternateLanguageEntries.map(({ lang: entryLang, href }) => <link rel="alternate" hreflang={languageLabels[entryLang]} href={href} />)}
<link rel="alternate" hreflang="x-default" href={xDefaultURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content={imageAlt ?? title} />
{imageWidth && <meta property="og:image:width" content={String(imageWidth)} />}
{imageHeight && <meta property="og:image:height" content={String(imageHeight)} />}
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={locale} />
{alternateOgLocales.map((alternateLocale) => <meta property="og:locale:alternate" content={alternateLocale} />)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />
<meta property="twitter:image:alt" content={imageAlt ?? title} />
<meta property="twitter:site" content="@blocktom" />
<meta property="twitter:creator" content="@blocktom" />

{structuredDataItems.map((item) => (
	<script type="application/ld+json" set:html={JSON.stringify(item)} />
))}
