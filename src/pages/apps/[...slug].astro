---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getEntrySlug, localizePath, UI } from '../../i18n';

export async function getStaticPaths() {
	const apps = await getCollection('apps', ({ data }) => !data.draft && data.lang === 'en');
	return apps.map((app) => ({
		params: { slug: getEntrySlug(app) },
		props: app,
	}));
}

type Props = CollectionEntry<'apps'>;

const app = Astro.props;
const { Content } = await render(app);
const lang = app.data.lang;
const text = UI[lang];
const appSlug = getEntrySlug(app);
const privacyPolicies = await getCollection('privacy', ({ data }) => !data.draft && data.lang === lang);
const privacyPolicy = privacyPolicies.find((policy) => policy.data.appSlug === appSlug);
const productUrl = new URL(localizePath(`/apps/${appSlug}/`, lang), Astro.site).href;
const privacyUrl = privacyPolicy
	? new URL(localizePath(`/apps/${appSlug}/privacy/`, lang), Astro.site).href
	: undefined;
const appImage = app.data.seoImage ?? app.data.heroImage ?? app.data.icon;
const appTitle = app.data.seoTitle ?? `${app.data.appName} - ${text.products}`;
const appDescription = app.data.seoDescription ?? app.data.description;
const supportTarget = app.data.supportUrl ?? (app.data.supportEmail ? `mailto:${app.data.supportEmail}` : undefined);
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'SoftwareApplication',
		name: app.data.appName,
		applicationCategory: 'ProductivityApplication',
		operatingSystem: app.data.platforms.join(', ') || 'iOS',
		description: appDescription,
		url: productUrl,
		image: appImage ? new URL(typeof appImage === 'string' ? appImage : appImage.src, Astro.site).href : undefined,
		screenshot: app.data.screenshots.map((screenshot) => new URL(screenshot, Astro.site).href),
		isAccessibleForFree: false,
		privacyPolicy: privacyUrl,
		sameAs: supportTarget ? [supportTarget] : undefined,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: text.products,
				item: new URL(localizePath('/apps/', lang), Astro.site).href,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: app.data.appName,
				item: productUrl,
			},
		],
	},
];
---

<!doctype html>
<html lang={text.htmlLang}>
	<head>
		<BaseHead title={appTitle} description={appDescription} image={appImage} type="product" structuredData={structuredData} />
		<style>
			main {
				width: 100%;
				max-width: 760px;
				padding: 6rem 1.5rem 5rem;
				box-sizing: border-box;
			}

			.product-head {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--border-color);
			}

			.meta {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.875rem;
				color: #6b7280;
				font-size: 0.875rem;
			}

			html.dark .meta {
				color: #9ca3af;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: 2.25rem;
				line-height: 1.2;
			}

			.description {
				margin: 0;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .description {
				color: #cbd5e1;
			}

			.actions {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				margin-top: 1.25rem;
			}

			.actions a {
				display: inline-flex;
				align-items: center;
				min-height: 40px;
				padding: 0.5rem 0.875rem;
				border: 1px solid var(--border-color);
				border-radius: 8px;
				color: var(--text-color);
				text-decoration: none;
				font-size: 0.9375rem;
				transition: border-color 0.2s ease, background-color 0.2s ease;
			}

			.actions a:hover {
				border-color: #6366f1;
				background-color: rgba(99, 102, 241, 0.06);
			}

			.prose {
				max-width: 100%;
				padding: 0;
			}

			@media (max-width: 720px) {
				main {
					padding: 5rem 1rem 4rem;
				}

				h1 {
					font-size: 1.875rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="product-head">
				<div class="meta">
					<span>{app.data.status}</span>
					{app.data.platforms.length > 0 && <span>{app.data.platforms.join(' / ')}</span>}
				</div>
				<h1>{app.data.appName}</h1>
				<p class="description">{app.data.description}</p>
				<div class="actions">
					{app.data.appStore && <a href={app.data.appStore}>{text.appStore}</a>}
					{app.data.website && <a href={app.data.website}>{text.productWebsite}</a>}
					{privacyPolicy && <a href={localizePath(`/apps/${appSlug}/privacy/`, lang)}>{text.privacyPolicy}</a>}
					{app.data.supportUrl && <a href={app.data.supportUrl}>Support</a>}
					{app.data.supportEmail && <a href={`mailto:${app.data.supportEmail}`}>{text.supportEmail}</a>}
				</div>
			</header>
			<article class="prose">
				<Content />
			</article>
		</main>
		<Footer />
	</body>
</html>
