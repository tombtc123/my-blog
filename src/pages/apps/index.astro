---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

const apps = (await getCollection('apps', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="产品 - Tom Blog" description="Tom 开发的 App 与产品介绍。" />
		<style>
			main {
				width: 100%;
				max-width: 960px;
				padding: 6rem 1.5rem 5rem;
				box-sizing: border-box;
			}

			.page-head {
				margin-bottom: 3rem;
			}

			.kicker {
				margin: 0 0 0.75rem;
				color: #6b7280;
				font-size: 0.875rem;
				font-weight: 600;
				letter-spacing: 0.04em;
			}

			html.dark .kicker {
				color: #9ca3af;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: 2.25rem;
				line-height: 1.2;
			}

			.lede {
				margin: 0;
				max-width: 640px;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .lede {
				color: #cbd5e1;
			}

			.collection-list {
				display: grid;
				gap: 1rem;
			}

			.product-card,
			.empty-state {
				display: block;
				padding: 1.25rem;
				border: 1px solid var(--border-color);
				border-radius: 8px;
				color: inherit;
				text-decoration: none;
				background: rgba(255, 255, 255, 0.4);
				transition: border-color 0.2s ease, transform 0.2s ease;
			}

			html.dark .product-card,
			html.dark .empty-state {
				background: rgba(255, 255, 255, 0.03);
			}

			.product-card:hover {
				border-color: #6366f1;
				transform: translateY(-1px);
			}

			.card-meta {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.75rem;
				color: #6b7280;
				font-size: 0.875rem;
			}

			html.dark .card-meta {
				color: #9ca3af;
			}

			.product-card h2,
			.empty-state h2 {
				margin: 0 0 0.5rem;
				font-size: 1.375rem;
				line-height: 1.3;
			}

			.product-card p,
			.empty-state p {
				margin: 0;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .product-card p,
			html.dark .empty-state p {
				color: #cbd5e1;
			}

			@media (max-width: 720px) {
				main {
					padding: 5rem 1rem 4rem;
				}

				h1 {
					font-size: 1.875rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<p class="kicker">Products</p>
				<h1>产品</h1>
				<p class="lede">这里会集中展示 Tom 开发的 App、工具和相关产品说明。每个产品页都会保留功能介绍、平台信息、下载入口，以及该 App 自己的隐私政策链接。</p>
			</section>

			<section class="collection-list" aria-label="产品列表">
				{apps.length > 0 ? (
					apps.map((app) => (
						<a class="product-card" href={`/apps/${app.id}/`}>
							<div class="card-meta">
								<span>{app.data.status}</span>
								{app.data.platforms.length > 0 && <span>{app.data.platforms.join(' / ')}</span>}
							</div>
							<h2>{app.data.appName}</h2>
							<p>{app.data.description}</p>
						</a>
					))
				) : (
					<div class="empty-state">
						<h2>产品页已准备好</h2>
						<p>后续新增 App 时，只需要添加一份产品 Markdown；如果这个 App 需要隐私政策，再添加对应隐私 Markdown，它会挂在该产品页面下面。</p>
					</div>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
