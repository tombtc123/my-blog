---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';
import { calculateReadingTime, formatDate, getEntrySlug, localizePath, UI } from '../../../i18n';

const lang = 'zh';
const text = UI[lang];

const posts = (await getCollection('blog', ({ data }) => data.lang === lang)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang={text.htmlLang}>
	<head>
		<BaseHead title={`${text.writing} - ${SITE_TITLE}`} description={text.writingPageDescription} />
		<style>
			main {
				width: 100%;
				max-width: 800px;
				padding: 6rem 1.5rem 5rem;
				box-sizing: border-box;
			}

			.page-head {
				margin-bottom: 3rem;
			}

			.kicker {
				margin: 0 0 0.75rem;
				color: #6b7280;
				font-size: 0.875rem;
				font-weight: 600;
				letter-spacing: 0.04em;
			}

			html.dark .kicker {
				color: #9ca3af;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: 2.25rem;
				line-height: 1.2;
			}

			.lede {
				margin: 0;
				max-width: 640px;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .lede {
				color: #cbd5e1;
			}

			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.post-item {
				margin-bottom: 3rem;
			}

			.post-item a {
				display: block;
				margin: -1rem;
				padding: 1rem;
				border-radius: 8px;
				color: inherit;
				text-decoration: none;
				transition: background-color 0.2s ease, transform 0.2s ease;
			}

			.post-item a:hover {
				background-color: rgba(99, 102, 241, 0.04);
				transform: translateY(-1px);
			}

			html.dark .post-item a:hover {
				background-color: rgba(99, 102, 241, 0.08);
			}

			.post-meta {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.75rem;
				color: #6b7280;
				font-size: 0.875rem;
			}

			html.dark .post-meta {
				color: #9ca3af;
			}

			.post-title {
				margin: 0 0 0.5rem;
				color: #6366f1;
				font-size: 1.75rem;
				line-height: 1.3;
			}

			.post-description {
				margin: 0;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .post-description {
				color: #cbd5e1;
			}

			@media (max-width: 720px) {
				main {
					padding: 5rem 1rem 4rem;
				}

				h1 {
					font-size: 1.875rem;
				}

				.post-title {
					font-size: 1.375rem;
					overflow-wrap: anywhere;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<p class="kicker">{text.writingArchive}</p>
				<h1>{text.writing}</h1>
				<p class="lede">{text.writingPageDescription}</p>
			</section>

			<ul class="post-list">
				{posts.map((post) => (
					<li class="post-item">
						<a href={localizePath(`/blog/${getEntrySlug(post)}/`, lang)}>
							<div class="post-meta">
								<span>{formatDate(post.data.pubDate, lang)}</span>
								<span>·</span>
								<span>{calculateReadingTime(post.body, lang)} {text.minRead}</span>
							</div>
							<h2 class="post-title">{post.data.title}</h2>
							<p class="post-description">{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
