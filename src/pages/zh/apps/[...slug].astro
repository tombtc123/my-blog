---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { APP_SITE_TITLE } from '../../../consts';
import { getEntrySlug, localizePath, UI } from '../../../i18n';

export async function getStaticPaths() {
	const apps = await getCollection('apps', ({ data }) => !data.draft && data.lang === 'zh');
	return apps.map((app) => ({
		params: { slug: getEntrySlug(app) },
		props: app,
	}));
}

type Props = CollectionEntry<'apps'>;

const app = Astro.props;
const { Content } = await render(app);
const lang = app.data.lang;
const text = UI[lang];
const appSlug = getEntrySlug(app);
const privacyPolicies = await getCollection('privacy', ({ data }) => !data.draft && data.lang === lang);
const privacyPolicy = privacyPolicies.find((policy) => policy.data.appSlug === appSlug);
const appTranslations = await getCollection(
	'apps',
	({ data }) => !data.draft && data.translationKey === (app.data.translationKey ?? app.id)
);
const alternateLanguages = Object.fromEntries(
	appTranslations.map((translation) => [
		translation.data.lang,
		new URL(localizePath(`/apps/${getEntrySlug(translation)}/`, translation.data.lang), Astro.site).href,
	])
);
const alternateHref = alternateLanguages[lang === 'en' ? 'zh' : 'en'] ?? null;
const productUrl = new URL(localizePath(`/apps/${appSlug}/`, lang), Astro.site).href;
const privacyUrl = privacyPolicy
	? new URL(localizePath(`/apps/${appSlug}/privacy/`, lang), Astro.site).href
	: undefined;
const appImage = app.data.seoImage ?? app.data.heroImage ?? app.data.icon;
const appTitle = app.data.seoTitle ?? `${app.data.appName} - ${text.products}`;
const appDescription = app.data.seoDescription ?? app.data.description;
const supportTarget = app.data.supportUrl ?? (app.data.supportEmail ? `mailto:${app.data.supportEmail}` : undefined);
const sameAsLinks = [app.data.appStore, supportTarget].filter(Boolean);
const structuredAppName = app.data.appStoreName ?? app.data.appName;
const publisherName = app.data.publisherName ?? 'Tom';
const structuredLanguage = lang === 'zh' ? 'zh-CN' : 'en';
const alternateNames = Array.from(new Set([app.data.appStoreName, ...(app.data.alternateNames ?? [])].filter(Boolean)));
const appImageUrl = appImage ? new URL(typeof appImage === 'string' ? appImage : appImage.src, Astro.site).href : undefined;
const screenshotUrls = app.data.screenshots.map((screenshot) => new URL(screenshot, Astro.site).href);
const pageEntityId = `${productUrl}#webpage`;
const appEntityId = `${productUrl}#software`;
const breadcrumbEntityId = `${productUrl}#breadcrumb`;
const faqEntityId = `${productUrl}#faq`;
const formatDate = (date?: Date) => date?.toISOString().slice(0, 10);
const mobilePlatforms = new Set(['iOS', 'iPadOS', 'watchOS', 'tvOS']);
const softwareApplicationType = app.data.platforms.some((platform) => mobilePlatforms.has(platform))
	? ['SoftwareApplication', 'MobileApplication']
	: 'SoftwareApplication';
const appIdentifier = [
	app.data.appStoreId ? { '@type': 'PropertyValue', propertyID: 'App Store ID', value: app.data.appStoreId } : undefined,
	app.data.bundleId ? { '@type': 'PropertyValue', propertyID: 'Bundle ID', value: app.data.bundleId } : undefined,
].filter(Boolean);
const appOffer =
	typeof app.data.price === 'number'
		? {
				'@type': 'Offer',
				price: String(app.data.price),
				priceCurrency: app.data.priceCurrency ?? 'USD',
				description: app.data.priceDescription,
				url: app.data.appStore ?? productUrl,
				availability: app.data.appStore ? 'https://schema.org/InStock' : undefined,
				seller: {
					'@type': 'Person',
					name: publisherName,
					url: new URL('/', Astro.site).href,
				},
			}
		: undefined;
const faqStructuredData =
	app.data.faq.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				'@id': faqEntityId,
				mainEntity: app.data.faq.map((item) => ({
					'@type': 'Question',
					name: item.question,
					acceptedAnswer: {
						'@type': 'Answer',
						text: item.answer,
					},
				})),
			}
		: undefined;
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': softwareApplicationType,
		'@id': appEntityId,
		name: structuredAppName,
		alternateName: alternateNames.length > 0 ? alternateNames : undefined,
		applicationCategory: app.data.applicationCategory,
		applicationSubCategory: app.data.tags?.join(', '),
		operatingSystem: app.data.platforms.join(', ') || undefined,
		softwareRequirements: app.data.minimumOsVersion,
		contentRating: app.data.contentRating,
		description: appDescription,
		url: productUrl,
		mainEntityOfPage: { '@id': pageEntityId },
		image: appImageUrl,
		screenshot: screenshotUrls,
		downloadUrl: app.data.appStore,
		installUrl: app.data.appStore,
		softwareVersion: app.data.softwareVersion,
		releaseDate: formatDate(app.data.releaseDate),
		datePublished: formatDate(app.data.pubDate),
		dateModified: formatDate(app.data.updatedDate ?? app.data.pubDate),
		identifier: appIdentifier.length > 0 ? appIdentifier : undefined,
		keywords: app.data.keywords?.join(', '),
		featureList: app.data.featureList.length > 0 ? app.data.featureList : undefined,
		learningResourceType: app.data.learningResourceType.length > 0 ? app.data.learningResourceType : undefined,
		educationalUse: app.data.educationalUse,
		teaches: app.data.teaches.length > 0 ? app.data.teaches : undefined,
		audience: app.data.audience.length > 0
			? app.data.audience.map((audienceName) => ({
					'@type': 'Audience',
					audienceType: audienceName,
				}))
			: undefined,
		inLanguage: structuredLanguage,
		isAccessibleForFree: typeof app.data.price === 'number' ? app.data.price === 0 : undefined,
		publisher: {
			'@type': 'Person',
			name: publisherName,
			url: new URL('/', Astro.site).href,
			sameAs: ['https://x.com/blocktom'],
		},
		offers: appOffer,
		privacyPolicy: privacyUrl,
		sameAs: sameAsLinks.length > 0 ? sameAsLinks : undefined,
		potentialAction: app.data.appStore
			? {
					'@type': 'InstallAction',
					target: app.data.appStore,
				}
			: undefined,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': pageEntityId,
		name: appTitle,
		description: appDescription,
		url: productUrl,
		inLanguage: structuredLanguage,
		primaryImageOfPage: appImageUrl,
		datePublished: formatDate(app.data.pubDate),
		dateModified: formatDate(app.data.updatedDate ?? app.data.pubDate),
		about: { '@id': appEntityId },
		mainEntity: { '@id': appEntityId },
		breadcrumb: { '@id': breadcrumbEntityId },
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		'@id': breadcrumbEntityId,
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: text.products,
				item: new URL(localizePath('/apps/', lang), Astro.site).href,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: app.data.appName,
				item: productUrl,
			},
		],
	},
	faqStructuredData,
].filter(Boolean);
---

<!doctype html>
<html lang={text.htmlLang}>
	<head>
		<BaseHead
			title={appTitle}
			description={appDescription}
			image={appImage}
			imageAlt={app.data.seoImageAlt}
			imageWidth={app.data.seoImageWidth}
			imageHeight={app.data.seoImageHeight}
			type="product"
			structuredData={structuredData}
			appStoreId={app.data.appStoreId}
			alternateLanguages={alternateLanguages}
			siteName={APP_SITE_TITLE}
			identityName={publisherName}
		/>
		<style>
			main {
				width: 100%;
				max-width: 760px;
				margin: 0 auto;
				padding: 6rem 1.5rem 5rem;
				box-sizing: border-box;
			}

			.product-head {
				min-width: 0;
				max-width: 100%;
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--border-color);
			}

			.meta {
				display: flex;
				align-items: center;
				gap: 0.625rem;
				flex-wrap: wrap;
				margin-bottom: 1rem;
				color: #6b7280;
				font-size: 0.875rem;
			}

			html.dark .meta {
				color: #9ca3af;
			}

			.store-status,
			.status-pill,
			.platform-pill {
				display: inline-flex;
				align-items: center;
				min-height: 34px;
				border-radius: 999px;
				font-size: 0.875rem;
				font-weight: 700;
				line-height: 1;
			}

			.store-status {
				gap: 0.5rem;
				padding: 0.5rem 0.75rem 0.5rem 0.625rem;
				border: 1px solid rgba(16, 185, 129, 0.28);
				background:
					linear-gradient(135deg, rgba(215, 255, 95, 0.95), rgba(94, 234, 212, 0.48)),
					#ffffff;
				color: #101114;
				text-decoration: none;
				box-shadow: 0 12px 28px rgba(16, 185, 129, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.68);
				transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
			}

			a.store-status:hover {
				border-color: rgba(16, 185, 129, 0.5);
				color: #101114;
				box-shadow: 0 16px 34px rgba(16, 185, 129, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.72);
				transform: translateY(-1px);
			}

			html.dark .store-status {
				border-color: rgba(215, 255, 95, 0.32);
				background:
					linear-gradient(135deg, rgba(215, 255, 95, 0.96), rgba(94, 234, 212, 0.58)),
					#111318;
				box-shadow: 0 14px 36px rgba(215, 255, 95, 0.1);
			}

			.store-status-mark {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 22px;
				height: 22px;
				border-radius: 50%;
				background: #101114;
				color: #d7ff5f;
				box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.12);
			}

			.store-status-mark svg,
			.store-status-arrow {
				width: 14px;
				height: 14px;
				flex: 0 0 auto;
			}

			.platform-pill {
				padding: 0.5rem 0.75rem;
				border: 1px solid var(--border-color);
				background: rgba(99, 102, 241, 0.06);
				color: #4b5563;
			}

			.status-pill {
				padding: 0.5rem 0.75rem;
				border: 1px solid var(--border-color);
				background: rgba(107, 114, 128, 0.06);
				color: #4b5563;
			}

			html.dark .platform-pill,
			html.dark .status-pill {
				background: rgba(255, 255, 255, 0.05);
				color: #cbd5e1;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: 2.25rem;
				line-height: 1.2;
			}

			.description {
				max-width: 100%;
				margin: 0;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
				overflow-wrap: anywhere;
			}

			html.dark .description {
				color: #cbd5e1;
			}

			.actions {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				margin-top: 1.25rem;
			}

			.actions a {
				display: inline-flex;
				align-items: center;
				min-height: 40px;
				padding: 0.5rem 0.875rem;
				border: 1px solid var(--border-color);
				border-radius: 8px;
				color: var(--text-color);
				text-decoration: none;
				font-size: 0.9375rem;
				transition: border-color 0.2s ease, background-color 0.2s ease;
			}

			.actions a:hover {
				border-color: #6366f1;
				background-color: rgba(99, 102, 241, 0.06);
			}

			.prose {
				max-width: 100%;
				padding: 0;
			}

			@media (max-width: 720px) {
				main {
					padding: 5rem 1rem 4rem;
				}

				h1 {
					font-size: 1.875rem;
				}

				.meta {
					align-items: flex-start;
				}

				.store-status {
					flex: 1 1 100%;
					justify-content: center;
					max-width: 100%;
					white-space: normal;
				}

				.status-pill,
				.platform-pill {
					max-width: 100%;
				}
			}
		</style>
	</head>
	<body>
		<Header alternateHref={alternateHref} />
		<main>
			<header class="product-head">
				<div class="meta">
					{
						app.data.appStore ? (
							<a class="store-status" href={app.data.appStore} target="_blank" rel="noopener noreferrer" aria-label={`在 App Store 打开 ${app.data.appName}`}>
								<span class="store-status-mark" aria-hidden="true">
									<svg viewBox="0 0 24 24" fill="none">
										<path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
									</svg>
								</span>
								<span>{app.data.status}</span>
								<svg class="store-status-arrow" viewBox="0 0 24 24" fill="none" aria-hidden="true">
									<path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
								</svg>
							</a>
						) : (
							<span class="status-pill">{app.data.status}</span>
						)
					}
					{app.data.platforms.length > 0 && <span class="platform-pill">{app.data.platforms.join(' / ')}</span>}
				</div>
				<h1>{app.data.appName}</h1>
				<p class="description">{app.data.description}</p>
				<div class="actions">
					{app.data.appStore && <a href={app.data.appStore}>{text.appStore}</a>}
					{app.data.website && <a href={app.data.website}>{text.productWebsite}</a>}
					{privacyPolicy && <a href={localizePath(`/apps/${appSlug}/privacy/`, lang)}>{text.privacyPolicy}</a>}
					{app.data.supportUrl && <a href={app.data.supportUrl}>支持</a>}
					{app.data.supportEmail && <a href={`mailto:${app.data.supportEmail}`}>{text.supportEmail}</a>}
				</div>
			</header>
			<article class="prose">
				<Content />
			</article>
		</main>
		<Footer />
	</body>
</html>
