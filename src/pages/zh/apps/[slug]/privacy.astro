---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../../../components/BaseHead.astro';
import Footer from '../../../../components/Footer.astro';
import Header from '../../../../components/Header.astro';
import { formatDate, getEntrySlug, localizePath, UI } from '../../../../i18n';

export async function getStaticPaths() {
	const policies = await getCollection('privacy', ({ data }) => !data.draft && data.lang === 'zh');
	const apps = await getCollection('apps', ({ data }) => !data.draft && data.lang === 'zh');

	return policies.map((policy) => ({
		params: { slug: policy.data.appSlug },
		props: {
			policy,
			app: apps.find((app) => getEntrySlug(app) === policy.data.appSlug),
		},
	}));
}

type Props = {
	policy: CollectionEntry<'privacy'>;
	app?: CollectionEntry<'apps'>;
};

const { policy, app } = Astro.props;
const { Content } = await render(policy);
const lang = policy.data.lang;
const text = UI[lang];
const policyUrl = new URL(localizePath(`/apps/${policy.data.appSlug}/privacy/`, lang), Astro.site).href;
const productUrl = new URL(localizePath(`/apps/${policy.data.appSlug}/`, lang), Astro.site).href;
const policyTitle = policy.data.seoTitle ?? policy.data.title;
const policyDescription = policy.data.seoDescription ?? policy.data.description;
const appOperatingSystem = app?.data.minimumOsVersion ?? (policy.data.platforms.join(', ') || 'iOS');
const structuredAppName = app?.data.appStoreName ?? policy.data.appName;
const policyTranslations = await getCollection(
	'privacy',
	({ data }) => !data.draft && data.translationKey === (policy.data.translationKey ?? policy.id)
);
const alternateLanguages = Object.fromEntries(
	policyTranslations.map((translation) => [
		translation.data.lang,
		new URL(localizePath(`/apps/${translation.data.appSlug}/privacy/`, translation.data.lang), Astro.site).href,
	])
);
const alternateHref = alternateLanguages[lang === 'en' ? 'zh' : 'en'] ?? null;
const structuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		name: policyTitle,
		description: policyDescription,
		url: policyUrl,
		isPartOf: {
			'@type': 'WebSite',
			name: 'Tom Blog',
			url: new URL('/', Astro.site).href,
		},
		about: {
			'@type': 'SoftwareApplication',
			name: structuredAppName,
			url: productUrl,
			operatingSystem: appOperatingSystem,
			applicationCategory: app?.data.applicationCategory ?? 'UtilitiesApplication',
		},
		datePublished: policy.data.pubDate.toISOString(),
		dateModified: (policy.data.updatedDate ?? policy.data.pubDate).toISOString(),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: text.products,
				item: new URL(localizePath('/apps/', lang), Astro.site).href,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: policy.data.appName,
				item: productUrl,
			},
			{
				'@type': 'ListItem',
				position: 3,
				name: text.privacyPolicy,
				item: policyUrl,
			},
		],
	},
];
---

<!doctype html>
<html lang={text.htmlLang}>
	<head>
		<BaseHead
			title={policyTitle}
			description={policyDescription}
			image={policy.data.seoImage}
			structuredData={structuredData}
			appStoreId={app?.data.appStoreId}
			alternateLanguages={alternateLanguages}
		/>
		<style>
			main {
				width: 100%;
				max-width: 760px;
				padding: 6rem 1.5rem 5rem;
				box-sizing: border-box;
			}

			.policy-head {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--border-color);
			}

			.meta {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.875rem;
				color: #6b7280;
				font-size: 0.875rem;
			}

			html.dark .meta {
				color: #9ca3af;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: 2.25rem;
				line-height: 1.2;
			}

			.description {
				margin: 0;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .description {
				color: #cbd5e1;
			}

			.prose {
				max-width: 100%;
				padding: 0;
			}

			.app-link {
				display: inline-flex;
				align-items: center;
				min-height: 40px;
				margin-top: 1.25rem;
				padding: 0.5rem 0.875rem;
				border: 1px solid var(--border-color);
				border-radius: 8px;
				color: var(--text-color);
				text-decoration: none;
				font-size: 0.9375rem;
			}

			.app-link:hover {
				border-color: #6366f1;
				background-color: rgba(99, 102, 241, 0.06);
			}

			@media (max-width: 720px) {
				main {
					padding: 5rem 1rem 4rem;
				}

				h1 {
					font-size: 1.875rem;
				}
			}
		</style>
	</head>
	<body>
		<Header alternateHref={alternateHref} />
		<main>
			<header class="policy-head">
				<div class="meta">
					<span>{policy.data.appName}</span>
					<span>{text.effectiveDate}: {formatDate(policy.data.effectiveDate, lang)}</span>
					<span>{text.version}: {policy.data.version}</span>
				</div>
				<h1>{policy.data.title}</h1>
				<p class="description">{policy.data.description}</p>
				{app && <a class="app-link" href={localizePath(`/apps/${getEntrySlug(app)}/`, lang)}>{text.backToProduct}</a>}
			</header>
			<article class="prose">
				<Content />
			</article>
		</main>
		<Footer />
	</body>
</html>
