---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import { getEntrySlug, localizePath, UI } from '../../../i18n';

const lang = 'zh';
const text = UI[lang];

const apps = (await getCollection('apps', ({ data }) => !data.draft && data.lang === lang)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang={text.htmlLang}>
	<head>
		<BaseHead title={`${text.products} - Tom Blog`} description={text.productsPageDescription} />
		<style>
			main {
				width: 100%;
				max-width: 960px;
				padding: 6rem 1.5rem 5rem;
				box-sizing: border-box;
			}

			.page-head {
				margin-bottom: 3rem;
			}

			.kicker {
				margin: 0 0 0.75rem;
				color: #6b7280;
				font-size: 0.875rem;
				font-weight: 600;
				letter-spacing: 0.04em;
			}

			html.dark .kicker {
				color: #9ca3af;
			}

			h1 {
				margin: 0 0 0.75rem;
				font-size: 2.25rem;
				line-height: 1.2;
			}

			.lede {
				margin: 0;
				max-width: 640px;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .lede {
				color: #cbd5e1;
			}

			.collection-list {
				display: grid;
				gap: 1rem;
			}

			.product-card,
			.empty-state {
				display: block;
				padding: 1.25rem;
				border: 1px solid var(--border-color);
				border-radius: 8px;
				color: inherit;
				text-decoration: none;
				background: rgba(255, 255, 255, 0.4);
				transition: border-color 0.2s ease, transform 0.2s ease;
			}

			html.dark .product-card,
			html.dark .empty-state {
				background: rgba(255, 255, 255, 0.03);
			}

			.product-card:hover {
				border-color: #6366f1;
				transform: translateY(-1px);
			}

			.card-meta {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-bottom: 0.75rem;
				color: #6b7280;
				font-size: 0.875rem;
			}

			html.dark .card-meta {
				color: #9ca3af;
			}

			.product-card h2,
			.empty-state h2 {
				margin: 0 0 0.5rem;
				font-size: 1.375rem;
				line-height: 1.3;
			}

			.product-card p,
			.empty-state p {
				margin: 0;
				color: #6b7280;
				font-size: 1rem;
				line-height: 1.7;
			}

			html.dark .product-card p,
			html.dark .empty-state p {
				color: #cbd5e1;
			}

			@media (max-width: 720px) {
				main {
					padding: 5rem 1rem 4rem;
				}

				h1 {
					font-size: 1.875rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-head">
				<p class="kicker">{text.productsAndPrivacy}</p>
				<h1>{text.products}</h1>
				<p class="lede">{text.productsPageDescription}</p>
			</section>

			<section class="collection-list" aria-label={text.products}>
				{apps.length > 0 ? (
					apps.map((app) => (
						<a class="product-card" href={localizePath(`/apps/${getEntrySlug(app)}/`, lang)}>
							<div class="card-meta">
								<span>{app.data.status}</span>
								{app.data.platforms.length > 0 && <span>{app.data.platforms.join(' / ')}</span>}
							</div>
							<h2>{app.data.appName}</h2>
							<p>{app.data.description}</p>
						</a>
					))
				) : (
					<div class="empty-state">
						<h2>{text.productsReady}</h2>
						<p>{text.productsReadyDescription}</p>
					</div>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
