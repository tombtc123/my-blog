---
import { Image } from 'astro:assets';
import type { CollectionEntry, MarkdownHeading } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { calculateReadingTime, formatDate, UI, type Lang } from '../i18n';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: MarkdownHeading[];
	body?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	headings = [],
	tags,
	category,
	body = '',
	lang = 'en',
} = Astro.props;
const activeLang = lang as Lang;
const text = UI[activeLang];
const readingTime = calculateReadingTime(body, activeLang);
const hasToc = headings.length > 0;
const showBackToTop = hasToc || body.length > 2200;

function getHeadingSlug(heading: MarkdownHeading): string {
	return heading.slug || heading.text.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').trim();
}
---

<!doctype html>
<html lang={text.htmlLang}>
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 5rem 1rem 5rem;
				overflow-x: clip;
				box-sizing: border-box;
			}

			.article-container {
				display: flex;
				align-items: flex-start;
				gap: 2rem;
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				box-sizing: border-box;
			}

			.prose {
				flex: 1;
				width: 100%;
				max-width: 65ch;
				min-width: 0;
				margin: 0 auto;
				font-size: 1.0625rem;
				line-height: 1.8;
				box-sizing: border-box;
			}

			.title {
				max-width: 100%;
				margin-bottom: 2rem;
				padding: 0;
				text-align: left;
			}

			.title h1 {
				margin: 0;
				color: var(--text-color);
				font-size: 1.875rem;
				font-weight: 700;
				line-height: 1.3;
				overflow-wrap: anywhere;
			}

			.article-meta {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 0.875rem;
				color: #6b7280;
				font-size: 0.9375rem;
				line-height: 1.5;
			}

			html.dark .article-meta {
				color: #9ca3af;
			}

			.hero-image {
				display: block;
				width: 100%;
				max-width: 100%;
				height: auto;
				max-height: 400px;
				object-fit: cover;
				border-radius: 8px;
				margin-bottom: 2rem;
			}

			.prose :global(h2) {
				margin-top: 3rem;
				margin-bottom: 1rem;
				padding-bottom: 0.5rem;
				border-bottom: 1px solid var(--border-color);
				font-size: 1.5rem;
				font-weight: 600;
			}

			.prose :global(h3) {
				margin-top: 2rem;
				margin-bottom: 0.75rem;
				font-size: 1.25rem;
				font-weight: 600;
			}

			.prose :global(p) {
				margin-bottom: 1.5rem;
			}

			.prose :global(h2),
			.prose :global(h3) {
				scroll-margin-top: 5rem;
			}

			.post-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 2rem;
				padding-top: 2rem;
				border-top: 1px solid var(--border-color);
			}

			.post-tag {
				border-radius: 999px;
				background-color: rgba(99, 102, 241, 0.1);
				color: #6366f1;
				font-size: 0.8125rem;
				padding: 0.25rem 0.75rem;
			}

			html.dark .post-tag {
				background-color: rgba(99, 102, 241, 0.15);
				color: #a5b4fc;
			}

			.toc {
				position: sticky;
				top: 5rem;
				width: 220px;
				max-height: calc(100vh - 6rem);
				overflow-y: auto;
				padding: 1rem 0;
				font-size: 0.875rem;
				line-height: 1.6;
			}

			.toc-title {
				margin-bottom: 0.75rem;
				color: #6b7280;
				font-size: 0.75rem;
				font-weight: 600;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}

			html.dark .toc-title {
				color: #9ca3af;
			}

			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.toc-item {
				margin-bottom: 0.5rem;
			}

			.toc-item-h3 {
				padding-left: 1rem;
			}

			.toc-link {
				display: block;
				padding: 0.25rem 0 0.25rem 0.75rem;
				border-left: 2px solid transparent;
				color: #6b7280;
				text-decoration: none;
				transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
			}

			html.dark .toc-link {
				color: #9ca3af;
			}

			.toc-link:hover {
				border-left-color: rgba(99, 102, 241, 0.45);
				background-color: rgba(99, 102, 241, 0.06);
				color: #4f46e5;
			}

			html.dark .toc-link:hover {
				color: #a5b4fc;
			}

			.mobile-toc-button,
			.back-to-top {
				position: fixed;
				right: 1.5rem;
				width: 48px;
				height: 48px;
				border: none;
				border-radius: 50%;
				background-color: #6366f1;
				color: #ffffff;
				box-shadow: 0 4px 12px rgba(99, 102, 241, 0.35);
				cursor: pointer;
				align-items: center;
				justify-content: center;
				z-index: 45;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}

			.mobile-toc-button:hover,
			.back-to-top:hover {
				box-shadow: 0 6px 16px rgba(99, 102, 241, 0.45);
				transform: translateY(-2px);
			}

			.mobile-toc-button {
				bottom: 6.5rem;
				display: none;
			}

			.back-to-top {
				bottom: 2rem;
				display: flex;
				text-decoration: none;
			}

			.mobile-toc-overlay {
				position: fixed;
				inset: 0;
				background-color: rgba(0, 0, 0, 0.5);
				z-index: 99;
				opacity: 0;
				pointer-events: none;
				transition: opacity 0.2s ease;
			}

			.mobile-toc-overlay.active {
				opacity: 1;
				pointer-events: auto;
			}

			.mobile-toc-panel {
				position: fixed;
				top: 0;
				right: 0;
				width: min(280px, 86vw);
				height: 100%;
				padding: 2rem 1.5rem;
				overflow-y: auto;
				background-color: var(--bg-color);
				box-shadow: -4px 0 12px rgba(0, 0, 0, 0.12);
				transform: translateX(100%);
				transition: transform 0.2s ease;
				z-index: 100;
			}

			.mobile-toc-panel.active {
				transform: translateX(0);
			}

			.mobile-toc-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				margin-bottom: 1.5rem;
			}

			.mobile-toc-close {
				margin: -0.5rem;
				padding: 0.5rem;
				border: none;
				background: transparent;
				color: var(--text-color);
				cursor: pointer;
				opacity: 0.72;
				transition: opacity 0.2s ease;
			}

			.mobile-toc-close:hover {
				opacity: 1;
			}

			@media (max-width: 1024px) {
				.article-container {
					flex-direction: column;
					padding: 0;
				}

				.prose {
					width: 100%;
					max-width: 100%;
				}

				.toc {
					display: none;
				}

				.mobile-toc-button {
					display: flex;
				}
			}

			@media (max-width: 768px) {
				main {
					padding: 4.75rem 1rem 5rem;
				}

				.title {
					margin-bottom: 1.5rem;
				}

				.title h1 {
					font-size: 2rem;
					line-height: 1.18;
				}

				.article-meta {
					margin-top: 0.75rem;
					font-size: 0.875rem;
				}

				.prose {
					padding: 0;
					font-size: 1.0625rem;
					line-height: 1.78;
					overflow-wrap: break-word;
					word-break: break-word;
				}

				.prose :global(p) {
					margin-bottom: 1.35rem;
				}

				.mobile-toc-button,
				.back-to-top {
					right: 1rem;
					width: 44px;
					height: 44px;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main id="top">
			<article>
				<div class="article-container">
					<div class="prose">
						<div class="title">
							<h1>{title}</h1>
							<div class="article-meta">
								<time datetime={pubDate.toISOString()}>{formatDate(pubDate, activeLang)}</time>
								<span>·</span>
								<span>{readingTime} {text.minRead}</span>
								{updatedDate && (
									<>
										<span>·</span>
										<time datetime={updatedDate.toISOString()}>{formatDate(updatedDate, activeLang)}</time>
									</>
								)}
								{category && (
									<>
										<span>·</span>
										<span>{category}</span>
									</>
								)}
							</div>
						</div>

						{heroImage && (
							<Image
								src={heroImage}
								alt={title}
								class="hero-image"
								widths={[640, 960]}
								sizes="(max-width: 720px) calc(100vw - 2rem), 680px"
								loading="eager"
								fetchpriority="high"
							/>
						)}

						<slot />

						{tags && tags.length > 0 && (
							<div class="post-tags" aria-label="Tags">
								{tags.map((tag) => (
									<span class="post-tag">{tag}</span>
								))}
							</div>
						)}
					</div>

					{hasToc && (
						<nav class="toc" id="toc" aria-label={text.tableOfContents}>
							<div class="toc-title">{text.contents}</div>
							<ul class="toc-list">
								{headings.map((heading) => {
									const slug = getHeadingSlug(heading);
									return (
										<li class={`toc-item ${heading.depth === 3 ? 'toc-item-h3' : ''}`}>
											<a href={`#${slug}`} class="toc-link">
												{heading.text}
											</a>
										</li>
									);
								})}
							</ul>
						</nav>
					)}
				</div>
			</article>
		</main>

		<Footer />

		{hasToc && (
			<>
				<button id="mobile-toc-button" class="mobile-toc-button" aria-label={text.tableOfContents}>
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<line x1="8" y1="6" x2="21" y2="6"></line>
						<line x1="8" y1="12" x2="21" y2="12"></line>
						<line x1="8" y1="18" x2="21" y2="18"></line>
						<line x1="3" y1="6" x2="3.01" y2="6"></line>
						<line x1="3" y1="12" x2="3.01" y2="12"></line>
						<line x1="3" y1="18" x2="3.01" y2="18"></line>
					</svg>
				</button>

				<div id="mobile-toc-overlay" class="mobile-toc-overlay"></div>

				<div id="mobile-toc-panel" class="mobile-toc-panel">
					<div class="mobile-toc-header">
						<div class="toc-title">{text.contents}</div>
						<button id="mobile-toc-close" class="mobile-toc-close" aria-label={text.close}>
							<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<line x1="18" y1="6" x2="6" y2="18"></line>
								<line x1="6" y1="6" x2="18" y2="18"></line>
							</svg>
						</button>
					</div>
					<ul class="toc-list">
						{headings.map((heading) => {
							const slug = getHeadingSlug(heading);
							return (
								<li class={`toc-item ${heading.depth === 3 ? 'toc-item-h3' : ''}`}>
									<a href={`#${slug}`} class="toc-link mobile-toc-link">
										{heading.text}
									</a>
								</li>
							);
						})}
					</ul>
				</div>

				<script>
					document.addEventListener('DOMContentLoaded', () => {
						const button = document.getElementById('mobile-toc-button');
						const overlay = document.getElementById('mobile-toc-overlay');
						const panel = document.getElementById('mobile-toc-panel');
						const closeButton = document.getElementById('mobile-toc-close');
						const links = document.querySelectorAll('.mobile-toc-link');

						function openToc() {
							overlay?.classList.add('active');
							panel?.classList.add('active');
							document.body.style.overflow = 'hidden';
						}

						function closeToc() {
							overlay?.classList.remove('active');
							panel?.classList.remove('active');
							document.body.style.overflow = '';
						}

						button?.addEventListener('click', openToc);
						closeButton?.addEventListener('click', closeToc);
						overlay?.addEventListener('click', closeToc);
						links.forEach((link) => link.addEventListener('click', closeToc));
						document.addEventListener('keydown', (event) => {
							if (event.key === 'Escape') closeToc();
						});
					});
				</script>
			</>
		)}

		{showBackToTop && (
			<a href="#top" class="back-to-top" aria-label={text.backToTop}>
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="m18 15-6-6-6 6"></path>
				</svg>
			</a>
		)}
	</body>
</html>
